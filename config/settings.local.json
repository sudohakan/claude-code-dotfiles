{
  "permissions": {
    "allow": [
      "Bash(test:*)",
      "Bash(wsl:*)",
      "Bash(wsl.exe --shutdown 2>&1 && echo \"WSL shutdown complete\")",
      "Bash(powershell.exe -Command \"wsl --shutdown\" 2>&1)",
      "Bash(powershell.exe -Command \"Get-Process -Name 'wsl','wslhost','wslservice' -ErrorAction SilentlyContinue | Format-Table Name,Id,CPU -AutoSize\" 2>&1)",
      "Bash(powershell.exe -Command \"Stop-Process -Name 'wsl' -Force -ErrorAction SilentlyContinue; Stop-Process -Name 'wslhost' -Force -ErrorAction SilentlyContinue; Stop-Process -Name 'wslservice' -Force -ErrorAction SilentlyContinue; Write-Host 'All WSL processes killed'\" 2>&1)",
      "Bash(powershell.exe -Command \"wsl --status\" 2>&1)",
      "Bash(powershell.exe -Command \"wsl -e echo 'WSL is working'\" 2>&1)",
      "Bash(netstat -ano)",
      "Bash(docker ps:*)",
      "Bash(docker stop:*)",
      "Bash(docker rm:*)",
      "Bash(docker run:*)",
      "Bash(where.exe claude:*)"
    ]
  }
}
