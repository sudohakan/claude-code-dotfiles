{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_SECURITY_REMINDER": "0",
    "ECC_HOOK_PROFILE": "balanced",
    "ENABLE_AUTOFORMAT": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" rotate-hook-approvals.js",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" retention-cleanup.js",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" hook-health-check.js",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" team-active-reminder.js",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" mcp-reconnect.js",
            "timeout": 30000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/dippy/bin/dippy-hook\""
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" pretooluse-safety.js"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" teammate-idle-check.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" task-completed-check.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" posttooluse-lint-format.js",
            "timeout": 20000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" mcp-health-check.js",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" session-end-check.js",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"$HOME/.claude/hooks/dippy/src/dippy/dippy_statusline.py\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "ralph-loop@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "mcpServers": {
    "container-use": {
      "command": "bash",
      "args": [
        "-c",
        "exec node \"$HOME/.claude/hooks/lib/mcp-launcher.js\" container-use"
      ],
      "startup_timeout_sec": 120
    }
  }
}
