{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/rotate-hook-approvals.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/retention-cleanup.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-health-check.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/team-active-reminder.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/dippy/bin/dippy-hook\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pretooluse-safety.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/teammate-idle-check.js\""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/task-completed-check.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "static-analysis@trailofbits": true,
    "differential-review@trailofbits": true,
    "insecure-defaults@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "audit-context-building@trailofbits": true,
    "property-based-testing@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "spec-to-code-compliance@trailofbits": true,
    "git-cleanup@trailofbits": true,
    "workflow-skill-design@trailofbits": true
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto",
  "mcpServers": {
    "container-use": {
      "command": "bash",
      "args": [
        "-c",
        "exec node \"$HOME/.claude/hooks/lib/mcp-launcher.js\" container-use"
      ],
      "startup_timeout_sec": 120
    },
    "HakanMCP": {
      "command": "bash",
      "args": [
        "-c",
        "exec node \"$HOME/.claude/hooks/lib/mcp-launcher.js\" hakanmcp"
      ],
      "startup_timeout_sec": 60
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@1.52.0-alpha-2025-03-20",
        "--cdp-endpoint",
        "http://localhost:9222"
      ]
    },
    "notebooklm": {
      "command": "npx",
      "args": [
        "-y",
        "@m4ykeldev/notebooklm-mcp",
        "serve"
      ]
    }
  }
}
