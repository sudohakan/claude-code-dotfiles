{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_SECURITY_REMINDER": "0",
    "ECC_HOOK_PROFILE": "strict"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" rotate-hook-approvals.js"
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" retention-cleanup.js"
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" hook-health-check.js"
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" team-active-reminder.js"
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" mcp-reconnect.js",
            "timeout": 30000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/dippy/bin/dippy-hook\""
          },
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" pretooluse-safety.js"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'You have no active task. Wait for the team lead to assign you work via SendMessage. Do not attempt to call TaskList or TaskUpdate.' >&2 && exit 0"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Task completing. Verify your output is correct (run tests, check files). Then notify team lead via SendMessage.' >&2 && exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{spawnSync:s}=require('child_process'),p=require('path').join(require('os').homedir(),'.claude','hooks',process.argv[1]),r=s(process.execPath,[p],{stdio:'inherit'});process.exit(r.status||0)\" session-end-check.js",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"$HOME/.claude/hooks/dippy/src/dippy/dippy_statusline.py\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "mcpServers": {
    "container-use": {
      "command": "bash",
      "args": [
        "-c",
        "exec node \"$HOME/.claude/hooks/lib/mcp-launcher.js\" container-use"
      ],
      "startup_timeout_sec": 120
    },
    "HakanMCP": {
      "command": "bash",
      "args": [
        "-c",
        "exec node \"$HOME/.claude/hooks/lib/mcp-launcher.js\" hakanmcp"
      ],
      "startup_timeout_sec": 60
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@1.52.0-alpha-2025-03-20",
        "--cdp-endpoint",
        "http://localhost:9222"
      ],
      "startup_timeout_sec": 30
    },
    "notebooklm": {
      "command": "npx",
      "args": [
        "-y",
        "@m4ykeldev/notebooklm-mcp",
        "serve"
      ]
    }
  }
}
