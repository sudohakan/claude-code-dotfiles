{
  "mcpServers": {
    "HakanMCP": {
      "type": "stdio",
      "command": "__NODE_COMMAND__",
      "args": [
        "__DEV_ROOT__/HakanMCP/dist/src/index.js"
      ],
      "env": {},
      "timeout": 30000
    },
    "notebooklm-mcp-cli": {
      "type": "stdio",
      "command": "notebooklm-mcp",
      "env": {}
    },
    "gtasks-mcp": {
      "type": "stdio",
      "command": "__NODE_COMMAND__",
      "args": [
        "__DEV_ROOT__/gtasks-mcp/dist/index.js"
      ],
      "env": {}
    },
    "infoset": {
      "type": "stdio",
      "command": "__DEV_ROOT_POSIX__/infoset-mcp/scripts/env-wrapper.sh",
      "args": [
        "__DEV_ROOT_POSIX__/infoset-mcp/src/mcp-server.mjs"
      ],
      "env": {},
      "timeout": 30000
    },
    "magic-21st": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic@latest"
      ],
      "env": {
        "API_KEY": ""
      }
    },
    "linkedin": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "linkedin-scraper-mcp"
      ]
    },
    "kali-mcp": {
      "type": "sse",
      "url": "http://localhost:8000/sse"
    },
    "n8n": {
      "type": "stdio",
      "command": "/home/hakan/.claude/scripts/n8n-mcp-wrapper.sh",
      "args": [],
      "env": {},
      "timeout": 60000
    }
  }
}
